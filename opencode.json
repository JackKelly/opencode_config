{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "google": {
      "options": {
        "setCacheKey": true
      }
    },
    "local_a6000": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local A6000 GPU",
      "options": {
        "baseURL": "http://workstation:8000/v1",
        "apiKey": "vllm-secret-key"
      },
      "models": {
        "Qwen/Qwen2.5-Coder-32B-Instruct-AWQ": {
          "name": "Qwen 2.5 32B Coder Instruct",
          "tool_call": true,
	  "limit": { "context": 0, "output": 8192 },
        },
        "Qwen/Qwen3.5-35B-A3B-GPTQ-Int4": {
          "name": "Qwen 3.5 35B MoE",
          "tool_call": true,
	  "limit": { "context": 0, "output": 8192 },
        },
        "Qwen/Qwen3.5-27B-GPTQ-Int4": {
          "name": "Qwen 3.5 27B dense",
          "tool_call": true,
	  "limit": { "context": 0, "output": 8192 },
        }
      }
    }
  }
}
